# Supabase (required for database / candidate queue features)
# Create a free project at https://supabase.com and run supabase/migrations/001_initial_schema.sql
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — never expose to browser bundles or client components
SUPABASE_SERVICE_ROLE_KEY=

# Google Sheets (required when approval append is enabled)
GOOGLE_SHEET_ID=
# Tab/sheet name inside the spreadsheet (default: Hackathons)
GOOGLE_SHEET_TAB=Hackathons
# Server-only — full service account JSON string; never expose to the browser
GOOGLE_SERVICE_ACCOUNT_JSON=
# Public browser URL for the "Open Sheet" link (safe to expose)
NEXT_PUBLIC_GOOGLE_SHEET_URL=

# Web search provider (optional — mock used when unset)
# SEARCH_PROVIDER=tavily|brave|exa|serpapi|mock
SEARCH_PROVIDER=
SEARCH_API_KEY=

# X / Twitter MCP (optional — app-only Bearer; never expose to browser)
# Mode: app-only (direct Streamable HTTP to api.x.com/mcp). No CLIENT_ID/SECRET.
X_MCP_MODE=app-only
X_MCP_URL=https://api.x.com/mcp
X_BEARER_TOKEN=
X_MAX_QUERIES_PER_RUN=6
X_MAX_POSTS_PER_QUERY=20
X_TOTAL_POST_LIMIT=60
X_REQUEST_TIMEOUT_MS=15000

# LLM provider (optional — deterministic parsing used when unset)
# LLM_PROVIDER=openai|anthropic|mock
LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=

# Explicit mock candidate queue for local UI development when Supabase is unreachable.
# Never silently enabled. Forbidden in production.
USE_MOCK_CANDIDATES=false

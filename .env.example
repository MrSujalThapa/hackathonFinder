# Public browser-safe values (NEXT_PUBLIC_* may be exposed to the browser)
# REQUIRED for full mode | OPTIONAL for demo/minimum local mode
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_GOOGLE_SHEET_URL=
NEXT_PUBLIC_SENTRY_DSN=

# ---------------------------------------------------------------------------
# Core application
# ---------------------------------------------------------------------------
# OPTIONAL — informational base URL for docs/smoke scripts
APP_URL=http://localhost:3000
# REQUIRED for web login (server-only). Plain password checked by the owner gate.
APP_PASSWORD=change-me
# REQUIRED for web sessions (server-only). At least 32 random characters.
# Example: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
APP_SESSION_SECRET=

# ---------------------------------------------------------------------------
# Demo / local fixtures (server-only flags)
# ---------------------------------------------------------------------------
# OPTIONAL — deterministic fixture Queue + forced dry-run persistence.
# Safe for a dedicated demo server. Does not silently enable itself.
DEMO_MODE=false
# OPTIONAL — development-only in-memory candidates. Forbidden in production
# unless DEMO_MODE=true or preview escape hatch below.
USE_MOCK_CANDIDATES=false
# Preview-only escape hatch; never set on production deployments.
ALLOW_MOCK_CANDIDATES_IN_PREVIEW=false

# ---------------------------------------------------------------------------
# Supabase (server-only service role)
# ---------------------------------------------------------------------------
# REQUIRED for full mode writes / Queue persistence
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---------------------------------------------------------------------------
# AI / enrichment (server-only)
# ---------------------------------------------------------------------------
# OPTIONAL — deterministic parsing used when unset
# LLM_PROVIDER=openai|mock
LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=
LLM_REQUEST_TIMEOUT_MS=20000
LLM_MAX_RETRIES=2
LLM_MAX_OUTPUT_TOKENS=1500
LLM_MAX_CALLS_PER_RUN=12
LLM_MAX_CALLS_PER_CANDIDATE=3

# ---------------------------------------------------------------------------
# Search (server-only)
# ---------------------------------------------------------------------------
# OPTIONAL — web collector degrades when unset (mock needs no key)
# SEARCH_PROVIDER=tavily|brave|exa|serpapi|mock
SEARCH_PROVIDER=
SEARCH_API_KEY=

# ---------------------------------------------------------------------------
# Google Sheets (server-only; optional integration)
# ---------------------------------------------------------------------------
# REQUIRED only when using approve → Sheet sync
GOOGLE_SHEET_ID=
GOOGLE_SHEET_TAB=Hackathons
# Full service-account JSON as a single line. private_key may contain \n escapes.
GOOGLE_SERVICE_ACCOUNT_JSON=
# Alias placeholders (not currently read by runtime; prefer GOOGLE_SHEET_* above)
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_PRIVATE_KEY=
# GOOGLE_SPREADSHEET_ID=
# GOOGLE_SHEET_NAME=

# ---------------------------------------------------------------------------
# Discovery runtime
# ---------------------------------------------------------------------------
# local = in-process Next.js executor (dev/demo)
# worker = enqueue only; external worker claims jobs
DISCOVERY_EXECUTION_MODE=local
WORKER_SHARED_SECRET=
DISCOVERY_MAX_ACTIVE_JOBS=2
DISCOVERY_MAX_QUEUED_JOBS=10
DISCOVERY_PUBLIC_SOURCE_CONCURRENCY=3
DISCOVERY_SOURCE_LOCK_WAIT_MS=60000
DISCOVERY_JOB_TIMEOUT_MS=600000
DISCOVERY_EVENT_RETENTION_DAYS=14

# Per-source enable flags (optional; defaults true for mlh/web/hacklist/devpost/luma/hakku)
# Runtime toggles in Settings write .data/source-settings.json and override these.
# SOURCE_MLH_ENABLED=true
# SOURCE_WEB_ENABLED=true
# SOURCE_HACKLIST_ENABLED=true
# SOURCE_DEVPOST_ENABLED=true
# SOURCE_LUMA_ENABLED=true
# SOURCE_HAKKU_ENABLED=true

# Browser profile root for Hakku (owner machine / private worker only)
BROWSER_PROFILE_ROOT=.data/browser-profiles
HAKKU_PROFILE_NAME=hakku
HAKKU_BROWSER_HEADLESS=true

# Terminal multi-session store: memory (DEV-ONLY) | supabase (requires migration 007)
# TERMINAL_SESSION_STORE=memory
# TERMINAL_ALLOW_MEMORY_STORE=false

# ---------------------------------------------------------------------------
# Persistence (emergency / debug only — not recommended)
# ---------------------------------------------------------------------------
# Discovery persistence is batch-only in normal operation.
# PERSISTENCE_STRATEGY=batch
# Emergency rollback only (dev/test). Never set in production.
# PERSISTENCE_ROLLBACK_V1=false
# PERSISTENCE_BATCH_VERIFY_AFTER_WRITE=false
# PERSISTENCE_BATCH_SHADOW=false

# ---------------------------------------------------------------------------
# X / Twitter MCP (optional; never required)
# ---------------------------------------------------------------------------
X_MCP_MODE=app-only
X_MCP_URL=https://api.x.com/mcp
X_BEARER_TOKEN=
X_MAX_QUERIES_PER_RUN=6
X_MAX_POSTS_PER_QUERY=20
X_TOTAL_POST_LIMIT=60
X_REQUEST_TIMEOUT_MS=15000

# ---------------------------------------------------------------------------
# Optional observability
# ---------------------------------------------------------------------------
SENTRY_DSN=

# ---------------------------------------------------------------------------
# Smoke / QA scripts only (never required for app boot)
# ---------------------------------------------------------------------------
# SMOKE_BASE_URL=http://localhost:3000

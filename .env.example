# Supabase (required for database / candidate queue features)
# Create a free project at https://supabase.com and run supabase/migrations/001_initial_schema.sql
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — never expose to browser bundles or client components
SUPABASE_SERVICE_ROLE_KEY=

# Google Sheets (required when approval append is enabled)
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=

# Web search provider (optional — mock used when unset)
# SEARCH_PROVIDER=tavily|brave|exa|serpapi|mock
SEARCH_PROVIDER=
SEARCH_API_KEY=

# X / Twitter MCP (optional)
X_BEARER_TOKEN=
X_MCP_URL=

# LLM provider (optional — deterministic parsing used when unset)
# LLM_PROVIDER=openai|anthropic|mock
LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=

# Explicit mock candidate queue for local UI development when Supabase is unreachable.
# Never silently enabled. Forbidden in production.
USE_MOCK_CANDIDATES=false

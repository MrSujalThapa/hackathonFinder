# Public browser-safe values
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_GOOGLE_SHEET_URL=
NEXT_PUBLIC_SENTRY_DSN=

# Server-only Supabase values
SUPABASE_SERVICE_ROLE_KEY=

# Owner-only web access
# Generate env-safe hash (preferred — no $ escaping):
#   npm run hash:password -- "my-long-password"
# Verify with the production verifier:
#   npm run verify:password -- "my-long-password"
APP_OWNER_PASSWORD_HASH_B64=
# Legacy (still supported). Prefer APP_OWNER_PASSWORD_HASH_B64.
APP_OWNER_PASSWORD_HASH=
# At least 32 random characters. Example:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
APP_SESSION_SECRET=

# Google Sheets
GOOGLE_SHEET_ID=
GOOGLE_SHEET_TAB=Hackathons
GOOGLE_SERVICE_ACCOUNT_JSON=

# Web search provider (optional; mock used when unset)
# SEARCH_PROVIDER=tavily|brave|exa|serpapi|mock
SEARCH_PROVIDER=
SEARCH_API_KEY=

# Per-source enable flags (optional; defaults true for mlh/web/hacklist/devpost/luma/hakku)
# Runtime toggles in Settings write .data/source-settings.json and override these.
# SOURCE_MLH_ENABLED=true
# SOURCE_WEB_ENABLED=true
# SOURCE_HACKLIST_ENABLED=true
# SOURCE_DEVPOST_ENABLED=true
# SOURCE_LUMA_ENABLED=true
# SOURCE_HAKKU_ENABLED=true

# X / Twitter MCP (optional; never required for production checks)
X_MCP_MODE=app-only
X_MCP_URL=https://api.x.com/mcp
X_BEARER_TOKEN=
X_MAX_QUERIES_PER_RUN=6
X_MAX_POSTS_PER_QUERY=20
X_TOTAL_POST_LIMIT=60
X_REQUEST_TIMEOUT_MS=15000

# LLM provider (optional; deterministic parsing used when unset)
# LLM_PROVIDER=openai|mock
LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=
LLM_REQUEST_TIMEOUT_MS=20000
LLM_MAX_RETRIES=2
LLM_MAX_OUTPUT_TOKENS=1500
LLM_MAX_CALLS_PER_RUN=12
LLM_MAX_CALLS_PER_CANDIDATE=3

# Optional server error reporting
SENTRY_DSN=

# Explicit mock candidate queue for local UI development only.
# Forbidden on production deployments.
USE_MOCK_CANDIDATES=false
# Preview-only escape hatch; never set on production deployments.
ALLOW_MOCK_CANDIDATES_IN_PREVIEW=false

# Discovery job runtime (web terminal + worker)
# local = in-process Next.js executor (dev/manual testing)
# worker = enqueue only; external worker claims and runs jobs
DISCOVERY_EXECUTION_MODE=local
WORKER_SHARED_SECRET=
DISCOVERY_MAX_ACTIVE_JOBS=1
DISCOVERY_JOB_TIMEOUT_MS=600000
DISCOVERY_EVENT_RETENTION_DAYS=14

# Hakku persistent browser profile (owner machine / private worker only)
# Relative paths resolve from process cwd. Absolute paths for mounted volumes.
# Example worker mount: BROWSER_PROFILE_ROOT=/data/browser-profiles
BROWSER_PROFILE_ROOT=.data/browser-profiles
HAKKU_PROFILE_NAME=hakku
# Collector/status default; source:connect always runs headed for manual login.
HAKKU_BROWSER_HEADLESS=true

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
Thumbs.db
Desktop.ini
*.pem
*.p12
.idea/
.vscode/*
!.vscode/extensions.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# env files — never commit secrets
.env
.env.local
.env.*.local
.env*.local

# Local runtime data (browser profiles, source settings, crawl plans) — never commit
.data/
.demo-output/
demo-output/
tmp/
temp/

# Auth / browser storage state
**/storage-state*.json
**/storageState*.json
**/auth-state*.json
**/auth.json
**/cookies.json

# Service account credentials
**/service-account*.json
**/*-service-account.json
**/credentials.json
**/google-credentials.json

# vercel / supabase local
.vercel
.supabase/
supabase/.branches
supabase/.temp

# typescript
*.tsbuildinfo

# local scrape dumps / probe scripts (may contain third-party client keys)
*_sample.html
*.rss
/scripts/inspect-*.mjs
/scripts/make-*-fixture.mjs
/scripts/probe-*.mjs
/devpost.rss
/devpost_sample.html
/hacklist_sample.html
/git
/main

# Local probe/audit traces (not production fixtures; do not commit phase snapshots)
.local-audits/

# Noisy generated design captures (keep curated after/ docs screenshots if needed)
artifacts/design/before/
artifacts/design/corrective-before/
artifacts/design/corrective-after/
artifacts/design/proposed/
artifacts/design/failed-redesign/

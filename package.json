{
  "name": "hackathon-approval-agent",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run build",
    "check:all": "npm run check && npm test && npm run check:supabase && npm run check:sheets && npm run check:llm && npm run check:prod",
    "check:supabase": "tsx scripts/check-supabase.ts",
    "check:x": "tsx scripts/check-x-mcp.ts",
    "check:llm": "tsx scripts/check-llm.ts",
    "check:sheets": "tsx scripts/check-google-sheets.ts",
    "check:prod": "tsx scripts/check-production-config.ts",
    "sync:sheets": "tsx src/cli/syncSheets.ts",
    "smoke:queue": "tsx scripts/smoke-queue.ts",
    "smoke:prod": "tsx scripts/smoke-production-auth.ts",
    "candidates:audit-sources": "tsx scripts/audit-candidate-sources.ts",
    "hash:password": "tsx scripts/hash-password.ts",
    "verify:password": "tsx scripts/verify-password.ts",
    "skills:sync": "tsx scripts/sync-agent-skills.ts",
    "skills:check": "tsx scripts/check-agent-skills.ts",
    "test": "tsx --test \"src/**/*.test.ts\" \"src/**/*.test.tsx\"",
    "agent": "tsx src/cli/agent.ts",
    "source:connect": "tsx scripts/source-browser.ts connect",
    "source:status": "tsx scripts/source-browser.ts status",
    "source:disconnect": "tsx scripts/source-browser.ts disconnect",
    "check:sources": "tsx scripts/check-sources.ts",
    "check:source": "tsx scripts/check-source.ts"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.0",
